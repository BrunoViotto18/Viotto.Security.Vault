  "version": "0.2.0",
  "configurations": [
    {
      "name": "cofre cifrar",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "cwd": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0",
      "program": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0/Viotto.Security.Vault.dll",
      "args": ["cifrar", "mensagem.txt"],
      "console": "integratedTerminal"
    },
    {
      "name": "cofre decifrar",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "cwd": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0",
      "program": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0/Viotto.Security.Vault.dll",
      "args": ["decifrar", "mensagem.txt.cifrado"],
      "console": "integratedTerminal"
    },
    {
      "name": "cofre testar",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "cwd": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0",
      "program": "${workspaceFolder}/src/Viotto.Security.Vault/bin/Debug/net10.0/Viotto.Security.Vault.dll",
      "args": ["testar"],
      "console": "integratedTerminal"
    }
  ]
}
