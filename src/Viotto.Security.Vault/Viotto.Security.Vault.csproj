<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Viotto.Security/Viotto.Security.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../assets/sample/mensagem.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <NistAssets Include="../../assets/nist/**/*.rsp" />
  </ItemGroup>

  <Target Name="CopyNistAssets" AfterTargets="Build">
    <Copy
      SourceFiles="@(NistAssets)"
      DestinationFiles="@(NistAssets->'$(OutDir)/nist/%(RecursiveDir)%(Filename)%(Extension)')"
    />
  </Target>

</Project>
